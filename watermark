<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root{
  --primary:#223243;
  --accent:#f5a623;
  --accent-dark:#e59712;
  --bg:#eef2f6;
  --card:rgba(255,255,255,0.88);
  --line:#e5ebf1;
  --muted:#758292;
  --ok:#27ae60;
  --danger:#e74c3c;
}
*{box-sizing:border-box;}
body{
  margin:0;
  font-family:'Cairo',sans-serif;
  background:
    radial-gradient(circle at top right, rgba(245,166,35,.08), transparent 24%),
    radial-gradient(circle at top left, rgba(34,50,67,.05), transparent 30%),
    var(--bg);
  color:#111;
}
.company-header{
  background-image:
    linear-gradient(rgba(34,50,67,.3), rgba(34,50,67,.3)),
    url('https://drive.google.com/thumbnail?id=1kGABjKDT_tHkUbce1CWMVVFfrbfJ1_P7&sz=w1400');
  background-size:cover;
  background-position:center;
  padding:28px 5% 60px;
  display:flex;
  align-items:center;
  gap:16px;
  color:#fff;
  flex-wrap:wrap;
  justify-content:center;
  text-align:center;
  box-shadow:0 12px 28px rgba(0,0,0,.18);
  position:relative;
  overflow:hidden;
}
.logo{
  width:100px;
  height:100px;
  background:#fff;
  border-radius:50%;
  padding:5px;
  object-fit:contain;
  display:block;
  flex-shrink:0;
}
.header-text{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:6px;
}
.header-text h1{
  color:#fff;
  margin:0;
  font-size:30px;
  font-weight:900;
}
.header-text p{
  color:#fff;
  margin:0;
  font-size:18px;
  font-weight:900;
}
.user-pill{
  margin-top:6px;
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:2px 14px;
  border-radius:999px;
  background:rgba(128,0,32,0.4);
  border:1px solid rgba(231,76,60,0.45);
  color:#fff;
  font-weight:900;
  font-size:13px;
}
.top-actions{
  width:100%;
  display:flex;
  justify-content:center;
  gap:10px;
  margin-top:10px;
  flex-wrap:wrap;
}
.top-btn{
  border:none;
  border-radius:12px;
  padding:10px 16px;
  background:rgba(255,255,255,.18);
  color:#fff;
  font-family:'Cairo';
  font-weight:900;
  cursor:pointer;
  border:1px solid rgba(255,255,255,.25);
}
.main-content{
  padding:0 5% 30px;
  display:flex;
  justify-content:center;
  margin-top:-40px;
  position:relative;
  z-index:2;
}
.card{
  width:100%;
  max-width:820px;
  background:rgba(255,255,255,0.88);
  border-radius:22px;
  padding:8px 12px;
  box-shadow:0 20px 50px rgba(0,0,0,.12),0 6px 18px rgba(0,0,0,.06);
  position:relative;
  z-index:2;
  backdrop-filter: blur(10px);
  border:1px solid rgba(255,255,255,.65);
}
.success{
  display:none;
  text-align:center;
  padding:34px 18px;
}
.success i{
  font-size:74px;
  color:var(--ok);
  margin-bottom:12px;
}
.success h2{
  margin:0 0 10px;
  font-weight:900;
  color:#1f2b36;
  font-size:24px;
}
.success p{
  margin:0 0 18px;
  color:var(--muted);
  font-weight:800;
  font-size:18px;
}
.again{
  border:none;
  border-radius:16px;
  padding:18px 20px;
  background:linear-gradient(180deg,#2ebf68,#26a65b);
  color:#fff;
  font-family:'Cairo';
  font-weight:900;
  font-size:20px;
  cursor:pointer;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  width:60%;
  max-width:420px;
  margin:25px auto 0;
}
.tabs{
  display:flex;
  gap:6px;
  justify-content:center;
  margin-bottom:8px;
  flex-wrap:wrap;
  background:#f9fbfd;
  border:1px solid var(--line);
  border-radius:14px;
  padding:4px;
}
.tab-btn{
  width:min(385px,100%);
  border-radius:10px;
  padding:6px 8px;
  font-weight:900;
  font-size:16px;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  border:none;
  background:transparent;
  font-family:'Cairo',sans-serif;
}
.tab-btn.primary{
  background:linear-gradient(180deg,var(--accent),var(--accent-dark));
  color:#fff;
}
.tab-btn.ghost{ color:#344454; }
.section{display:none;}
.section.active{display:block;}
.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:6px;
}
.row-2{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:6px;
  margin-top:4px;
}
.field{
  display:flex;
  flex-direction:column;
  gap:2px;
}
.field label{
  font-weight:900;
  font-size:15px;
  color:#253444;
}
input,select{
  width:100%;
  border:1.5px solid var(--line);
  border-radius:10px;
  padding:5px 10px;
  font-weight:800;
  font-size:14px;
  background:#fff;
  text-align:right;
  font-family:'Cairo',sans-serif;
  color:#1f2d3a;
  outline:none;
}
.main-action{
  margin-top:8px;
  width:100%;
  border:none;
  border-radius:12px;
  padding:7px 10px;
  background:linear-gradient(180deg,var(--accent),var(--accent-dark));
  color:#fff;
  font-weight:900;
  font-size:17px;
  cursor:pointer;
  font-family:'Cairo',sans-serif;
}
.main-action:disabled{ opacity:.65; cursor:not-allowed; }
.lab-box{ margin-top:4px; display:none; }
.toast{
  position:fixed;
  bottom:25px;
  left:50%;
  transform:translateX(-50%) translateY(20px);
  background:#223243;
  color:#fff;
  padding:14px 18px;
  border-radius:12px;
  font-weight:900;
  font-size:14px;
  box-shadow:0 10px 25px rgba(0,0,0,.25);
  opacity:0;
  pointer-events:none;
  transition:.35s;
  z-index:9999;
  min-width:220px;
  max-width:90%;
  text-align:center;
}
.toast.show{
  opacity:1;
  transform:translateX(-50%) translateY(0);
}
.toast.success{ background:#27ae60; }
.toast.error{ background:#e74c3c; }
.toast.warn{ background:#f39c12; }

#nID,#pID{
  font-size:20px;
  font-weight:600;
  color:#000;
  text-align:center;
  height:40px;
  width:100%;
}
#nClient{
  font-size:20px;
  font-weight:600;
  color:#000;
  height:40px;
  width:100%;
  text-align:right;
}
#pVal,#pDays{
  font-size:20px;
  font-weight:600;
  color:#000;
  text-align:right;
  height:40px;
  width:100%;
}
@media (max-width:820px){
  .header-text h1{ font-size:24px; }
  .header-text p{ font-size:15px; }
  .grid,.row-2{ grid-template-columns:1fr; }
  .card{ padding:10px; }
  .tab-btn{ width:100%; }
  .again{ width:100%; }
}
</style>
</head>

<body>
<div class="page-shell">
<header class="company-header">
  <img class="logo" src="https://drive.google.com/thumbnail?id=1NN7G2zhk7nhgXuPWGW4qE_pdGC-Ptjkt&sz=w500" alt="logo">
  <div class="header-text">
    <h1>الشركة العامة للفحص والتأهيل الهندسي</h1>
    <p><i class="fas fa-clipboard-list"></i> منصة تتبع اوامر العمل - اصدار امر العمل والتسعيرة</p>
    <div id="welcomeUser" class="user-pill"></div>
    <div class="top-actions">
      <button class="top-btn" type="button" onclick="goIndex()"><i class="fas fa-house"></i> الصفحة الرئيسية</button>
      <button class="top-btn" type="button" onclick="logout()"><i class="fas fa-right-from-bracket"></i> تسجيل الخروج</button>
    </div>
  </div>
</header>

<div class="page-content">
<main class="main-content">

  <div class="card" id="cardForm">
    <div class="tabs">
      <button class="tab-btn primary" id="tabNew" type="button" onclick="switchTab('new')">
        <i class="fas fa-plus-circle"></i> إضافة أمر عمل
      </button>

      <button class="tab-btn ghost" id="tabPrice" type="button" onclick="switchTab('price')">
        <i class="fas fa-receipt"></i> تثبيت التسعيرة
      </button>
    </div>

    <div class="section active" id="secNew">
      <div class="grid">
        <div class="field">
          <label>رقم أمر العمل</label>
          <input id="nID" type="text" placeholder="ادخل رقم أمر العمل" inputmode="numeric">
        </div>
        <div class="field">
          <label>اسم الجهة المستفيدة</label>
          <input id="nClient" type="text" placeholder="اسم الجهة">
        </div>
      </div>

      <button class="main-action" id="btnNew" type="button" onclick="saveNew()">
        اعتماد وحفظ البيانات
      </button>
    </div>

    <div class="section" id="secPrice">
      <div class="field">
        <label>رقم أمر العمل</label>
        <input id="pID" type="text" placeholder="ادخل رقم أمر العمل" inputmode="numeric">
      </div>

      <div class="row-2">
        <div class="field">
          <label>التسعيرة</label>
          <input id="pVal" type="number" placeholder="0">
        </div>
        <div class="field">
          <label>عدد الأيام</label>
          <input id="pDays" type="number" placeholder="0">
        </div>
      </div>

      <div class="field">
        <label>نوع الفحص</label>
        <select id="pType" onchange="toggleLab(this.value)">
          <option value="">اختر النوع</option>
          <option value="مختبرات">الفحص المختبري</option>
          <option value="مصاعد">فحص المصاعد</option>
        </select>
      </div>

      <div class="lab-box" id="labBox">
        <div class="field">
          <label>التوجيه</label>
          <select id="pLabVal">
            <option value="ورشة">ورشة</option>
            <option value="مختبرات فقط">مختبرات فقط</option>
          </select>
        </div>
      </div>

      <button class="main-action" id="btnPrice" type="button" onclick="savePrice()">
        اعتماد وحفظ البيانات
      </button>
    </div>
  </div>

  <div class="card success" id="cardSuccess">
    <i class="fas fa-check-circle"></i>
    <h2>تم الحفظ بنجاح</h2>
    <p id="successText">تم توثيق العملية في السجل الموحد.</p>

    <button class="again" type="button" onclick="resetAll()">
      <i class="fas fa-plus"></i> معاملة جديدة
    </button>
  </div>

</main>
</div>
</div>

<div id="toast" class="toast"></div>

<script>
const API_BASE = "https://script.google.com/macros/s/AKfycbwlfQBNdbqiomWXBF6SPvGURgOklgeAbJTBK18NUS_wx30MJWdSF0EhPSKkw5WCiuM/exec";
const TOKEN_KEY = "app_token";
const USER_KEY = "app_userName";
const ROLE_KEY = "app_role";

function normalizeOrderNo(value){
  return String(value || "")
    .replace(/[٠-٩]/g, d => "٠١٢٣٤٥٦٧٨٩".indexOf(d))
    .replace(/[۰-۹]/g, d => "۰۱۲۳۴۵۶۷۸۹".indexOf(d))
    .replace(/\s+/g, "")
    .trim();
}

function getToken(){ return localStorage.getItem(TOKEN_KEY) || ""; }
function getUserName(){ return localStorage.getItem(USER_KEY) || ""; }

function clearSession(){
  localStorage.removeItem(TOKEN_KEY);
  localStorage.removeItem(USER_KEY);
  localStorage.removeItem(ROLE_KEY);
}

async function apiGet(params){
  const url = new URL(API_BASE);
  Object.keys(params || {}).forEach(k => url.searchParams.set(k, params[k]));
  url.searchParams.set("_t", Date.now());

  const res = await fetch(url.toString(), {
    method: "GET",
    cache: "no-store"
  });

  if(!res.ok) throw new Error("فشل الاتصال بالسيرفر");
  return await res.json();
}

async function apiPost(data){
  const res = await fetch(API_BASE, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(data || {})
  });

  if(!res.ok) throw new Error("فشل الاتصال بالسيرفر");
  return await res.json();
}

function showToast(msg, type){
  const t = document.getElementById("toast");
  t.className = "toast " + (type || "success");
  t.innerText = msg || "";
  t.classList.add("show");
  clearTimeout(window.toastTimer);
  window.toastTimer = setTimeout(() => t.classList.remove("show"), 3000);
}

function switchTab(which){
  const tabNew = document.getElementById("tabNew");
  const tabPrice = document.getElementById("tabPrice");
  const secNew = document.getElementById("secNew");
  const secPrice = document.getElementById("secPrice");

  if(which === "new"){
    secNew.classList.add("active");
    secPrice.classList.remove("active");
    tabNew.classList.add("primary");
    tabNew.classList.remove("ghost");
    tabPrice.classList.add("ghost");
    tabPrice.classList.remove("primary");
  }else{
    secPrice.classList.add("active");
    secNew.classList.remove("active");
    tabPrice.classList.add("primary");
    tabPrice.classList.remove("ghost");
    tabNew.classList.add("ghost");
    tabNew.classList.remove("primary");
  }
}

function toggleLab(v){
  document.getElementById("labBox").style.display = (v === "مختبرات") ? "block" : "none";
}

function showSuccess(text){
  document.getElementById("successText").innerText = text || "تم توثيق العملية في السجل الموحد.";
  document.getElementById("cardForm").style.display = "none";
  document.getElementById("cardSuccess").style.display = "block";
}

function resetAll(){
  document.getElementById("cardSuccess").style.display = "none";
  document.getElementById("cardForm").style.display = "block";
  document.querySelectorAll("input").forEach(i => i.value = "");
  document.querySelectorAll("select").forEach(s => s.selectedIndex = 0);
  toggleLab("");
  switchTab("new");
  document.getElementById("btnNew").disabled = false;
  document.getElementById("btnNew").innerHTML = "اعتماد وحفظ البيانات";
  document.getElementById("btnPrice").disabled = false;
  document.getElementById("btnPrice").innerHTML = "اعتماد وحفظ البيانات";
}

function goIndex(){
  window.location.href = "index.html";
}

async function logout(){
  const token = getToken();

  try{
    if(token){
      await apiGet({
        action: "logout",
        token: token
      });
    }
  }catch(_){}

  clearSession();
  window.location.href = "login.html?page=plan-app.html";
}

async function requireAuth(){
  const token = getToken();

  if(!token){
    window.location.replace("login.html?page=plan-app.html");
    return false;
  }

  try{
    const res = await apiGet({
      action: "checkSession",
      token: token,
      page: "plan"
    });

    if(!res || !res.ok || !res.valid || !res.allowed){
      clearSession();
      window.location.replace("login.html?page=plan-app.html");
      return false;
    }

    const userName = res.userName || getUserName() || "مخول غير معروف";
    document.getElementById("welcomeUser").innerHTML =
      '<i class="fas fa-user-shield"></i> المستخدم: ' + userName;

    return true;

  }catch(_){
    clearSession();
    window.location.replace("login.html?page=plan-app.html");
    return false;
  }
}

async function saveNew(){
  const id = normalizeOrderNo(document.getElementById("nID").value);
  const cl = String(document.getElementById("nClient").value || "").trim();
  const userName = getUserName() || "مخول غير معروف";

  if(!id || !cl){
    showToast("اكمل البيانات", "warn");
    return;
  }

  const btn = document.getElementById("btnNew");
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';

  try{
    const r = await apiPost({
      action: "addNewOrder",
      orderNo: id,
      clientName: cl,
      userName: userName
    });

    const msg = String((r && (r.message || r.error)) || "");

    if(r && r.ok && msg.includes("✅")){
      showSuccess("تم إضافة أمر العمل وتوثيقة");
      showToast("تم الحفظ بنجاح", "success");
    }else{
      showToast(msg || "تعذر حفظ البيانات", "error");
      btn.disabled = false;
      btn.innerHTML = "اعتماد وحفظ البيانات";
    }
  }catch(err){
    showToast("خطأ: " + (err && err.message ? err.message : err), "error");
    btn.disabled = false;
    btn.innerHTML = "اعتماد وحفظ البيانات";
  }
}

async function savePrice(){
  const type = document.getElementById("pType").value;
  const userName = getUserName() || "مخول غير معروف";

  const d = {
    action: "processPlanning",
    orderNo: normalizeOrderNo(document.getElementById("pID").value),
    price: String(document.getElementById("pVal").value || "").trim(),
    days: String(document.getElementById("pDays").value || "").trim(),
    testType: type,
    labPath: (type === "مختبرات") ? document.getElementById("pLabVal").value : "",
    userName: userName
  };

  if(!d.orderNo || !d.testType){
    showToast("اكمل الحقول", "warn");
    return;
  }

  const btn = document.getElementById("btnPrice");
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';

  try{
    const r = await apiPost(d);
    const msg = String((r && (r.message || r.error)) || "");

    if(r && r.ok && msg.includes("✅")){
      showSuccess("تم تثبيت التسعيرة وعدد الايام وتوثيقة");
      showToast("تم تثبيت التسعيرة بنجاح", "success");
    }else{
      showToast(msg || "تعذر حفظ البيانات", "error");
      btn.disabled = false;
      btn.innerHTML = "اعتماد وحفظ البيانات";
    }
  }catch(err){
    showToast("خطأ: " + (err && err.message ? err.message : err), "error");
    btn.disabled = false;
    btn.innerHTML = "اعتماد وحفظ البيانات";
  }
}

window.addEventListener("load", async function(){
  const ok = await requireAuth();
  if(!ok) return;
  toggleLab("");
});
</script>

</body>
</html>
